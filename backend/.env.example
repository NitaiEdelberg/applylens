# Copy to .env and fill in. Get a free Groq key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
# Optional overrides
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Optional accounts + cloud tracker (Circle 3) ----
# DATABASE_URL is OPTIONAL. Unset -> a local SQLite file (sqlite:///./applylens.db),
# so accounts + the cloud tracker work locally with no credential. In production
# set it to your Supabase SESSION POOLER URI (Project Settings -> Database ->
# Connection string -> Session pooler). A `postgres://` scheme is auto-normalized
# to `postgresql://`.
# DATABASE_URL=postgresql://postgres:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# JWT_SECRET signs auth tokens. A dev fallback is used if unset (fine locally);
# set a long random value in production.
# JWT_SECRET=change-me-to-a-long-random-string

# ---- Optional RAG career corpus (Circle 4) ----
# RAG embeddings are OPTIONAL. With no key, retrieval uses a local, deterministic
# scikit-learn TF-IDF embedder (no network) — the whole feature works with no
# credential. Set a key below to activate real hosted embeddings.
# Preference order: JINA_API_KEY -> GEMINI_API_KEY -> local TF-IDF.
#
# JINA (recommended: free, NO credit card, no region limit). Get a key at
# https://jina.ai/embeddings
# JINA_API_KEY=jina_your_key_here
# JINA_EMBED_MODEL=jina-embeddings-v3
#
# GEMINI (note: its free tier is region/billing-limited — may fall back to TF-IDF).
# GEMINI_API_KEY=your_gemini_key_here
# GEMINI_EMBED_MODEL=text-embedding-004

# ---- Optional Elasticsearch full-text search (Circle 5) ----
# ELASTICSEARCH_URL is OPTIONAL. Unset -> GET /api/tracker/search falls back to a
# case-insensitive DB substring match on title/company, so search works with no
# credential. Set it to a full URL WITH credentials embedded — Bonsai/Elastic
# Cloud give you exactly this: https://USER:PASS@host. BONSAI_URL is accepted as
# an alias. Uses plain httpx against the ES REST API (no version-coupled client).
# ELASTICSEARCH_URL=https://user:pass@your-cluster.bonsaisearch.net:443
# ELASTICSEARCH_INDEX=applylens-apps
